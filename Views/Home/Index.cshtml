@{
    ViewData["Title"] = "BookExchange";
}

<style>
    /* ── Hero ── */
    .hero {
        background: linear-gradient(150deg, #2C1A0E 0%, #4A2A18 50%, #6B3A2A 100%);
        color: #F0E6D3;
        padding: 5rem 1rem 4.5rem;
        text-align: center;
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        inset: 0;
        background-image:
            radial-gradient(circle at 20% 50%, rgba(200,149,108,0.12) 0%, transparent 55%),
            radial-gradient(circle at 80% 20%, rgba(200,149,108,0.08) 0%, transparent 45%);
        pointer-events: none;
    }

    .hero-badge {
        display: inline-block;
        background: rgba(200,149,108,0.22);
        border: 1px solid rgba(200,149,108,0.45);
        color: #C8956C;
        border-radius: 20px;
        padding: 0.35rem 1.1rem;
        font-size: 0.82rem;
        font-family: sans-serif;
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 1.5rem;
    }

    .hero h1 {
        font-size: clamp(2rem, 5vw, 3.2rem);
        font-weight: bold;
        line-height: 1.2;
        margin-bottom: 1.25rem;
        color: #FAF6F1;
    }

    .hero h1 span {
        color: #C8956C;
    }

    .hero-desc {
        font-size: clamp(1rem, 2.5vw, 1.15rem);
        color: #C8B99A;
        max-width: 560px;
        margin: 0 auto 2.5rem;
        line-height: 1.7;
        font-family: sans-serif;
    }

    .hero-cta {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        background: linear-gradient(135deg, #C8956C, #A87040);
        border: none;
        color: #2C1A0E;
        padding: 0.85rem 2rem;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 700;
        text-decoration: none;
        font-family: sans-serif;
        transition: all 0.2s;
        display: inline-block;
    }

    .btn-hero-primary:hover {
        background: linear-gradient(135deg, #D9A87D, #C8956C);
        color: #2C1A0E;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(200,149,108,0.4);
    }

    .btn-hero-outline {
        background: transparent;
        border: 2px solid rgba(240,230,211,0.45);
        color: #F0E6D3;
        padding: 0.85rem 2rem;
        border-radius: 10px;
        font-size: 1rem;
        font-weight: 600;
        text-decoration: none;
        font-family: sans-serif;
        transition: all 0.2s;
        display: inline-block;
    }

    .btn-hero-outline:hover {
        border-color: rgba(240,230,211,0.8);
        background: rgba(240,230,211,0.1);
        color: #FAF6F1;
        transform: translateY(-2px);
    }

    /* ── Stats strip ── */
    .stats-strip {
        background: #FAF6F1;
        border-bottom: 1px solid #E8D5B0;
        padding: 1.75rem 0;
    }

    .stat-item {
        text-align: center;
        padding: 0 1rem;
    }

    .stat-number {
        font-size: 1.75rem;
        font-weight: bold;
        color: #6B3A2A;
        line-height: 1;
        margin-bottom: 0.25rem;
    }

    .stat-label {
        font-size: 0.8rem;
        color: #8B7355;
        font-family: sans-serif;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    /* ── How it works ── */
    .section {
        padding: 4rem 0;
    }

    .section-title {
        color: #2C1A0E;
        font-size: 1.75rem;
        font-weight: bold;
        text-align: center;
        margin-bottom: 0.5rem;
    }

    .section-subtitle {
        color: #8B7355;
        text-align: center;
        font-size: 0.95rem;
        margin-bottom: 3rem;
        font-family: sans-serif;
    }

    .step-card {
        text-align: center;
        padding: 2rem 1.5rem;
        border-radius: 14px;
        background: white;
        border: 1px solid #EDE0CC;
        box-shadow: 0 2px 12px rgba(44,26,14,0.06);
        transition: transform 0.2s, box-shadow 0.2s;
        height: 100%;
    }

    .step-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 28px rgba(44,26,14,0.1);
    }

    .step-icon {
        width: 60px;
        height: 60px;
        background: linear-gradient(135deg, #F0E6D3, #E8D5B0);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.6rem;
        margin: 0 auto 1.25rem;
        border: 2px solid #D4B896;
    }

    .step-number {
        display: inline-block;
        background: #6B3A2A;
        color: white;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        font-size: 0.75rem;
        font-weight: 700;
        line-height: 22px;
        text-align: center;
        font-family: sans-serif;
        margin-bottom: 0.75rem;
    }

    .step-card h3 {
        color: #2C1A0E;
        font-size: 1.05rem;
        margin-bottom: 0.6rem;
        font-weight: bold;
    }

    .step-card p {
        color: #8B7355;
        font-size: 0.875rem;
        line-height: 1.6;
        margin: 0;
        font-family: sans-serif;
    }

    /* ── Genre chips display ── */
    .genres-section {
        background: #F0E6D3;
        padding: 3.5rem 0;
    }

    .genre-tag {
        display: inline-block;
        background: white;
        border: 1.5px solid #D4B896;
        color: #6B3A2A;
        border-radius: 20px;
        padding: 0.45rem 1.1rem;
        font-size: 0.875rem;
        font-family: sans-serif;
        font-weight: 600;
        margin: 0.3rem;
        transition: all 0.18s;
    }

    .genre-tag:hover {
        background: #6B3A2A;
        border-color: #6B3A2A;
        color: white;
        transform: translateY(-1px);
    }

    /* ── CTA bottom ── */
    .cta-section {
        background: linear-gradient(135deg, #2C1A0E, #5A3020);
        padding: 4rem 1rem;
        text-align: center;
        color: #F0E6D3;
    }

    .cta-section h2 {
        font-size: 1.8rem;
        margin-bottom: 0.75rem;
        color: #FAF6F1;
    }

    .cta-section p {
        color: #C8B99A;
        font-family: sans-serif;
        font-size: 1rem;
        margin-bottom: 2rem;
        max-width: 500px;
        margin-left: auto;
        margin-right: auto;
    }
</style>

<!-- Hero -->
<section class="hero">
    <div class="container position-relative" style="z-index:1">
        <div class="hero-badge">&#128218; Platforma za razmenu knjiga</div>
        <h1>Podeli knjige.<br><span>Osvoji nove.</span></h1>
        <p class="hero-desc">
            Poveži se sa čitaocima u svom gradu, pozajmljuj omiljene naslove
            i daj drugima šansu da uživaju u knjigama koje su stajale na tvojoj polici.
        </p>
        <div class="hero-cta">
            <a asp-controller="Account" asp-action="Register" class="btn-hero-primary">
                Počni besplatno
            </a>
            <a asp-controller="Account" asp-action="Login" class="btn-hero-outline">
                Prijavi se
            </a>
        </div>
    </div>
</section>

<!-- Stats -->
<div class="stats-strip">
    <div class="container">
        <div class="row justify-content-center g-3">
            <div class="col-4 col-md-2">
                <div class="stat-item">
                    <div class="stat-number">100%</div>
                    <div class="stat-label">Besplatno</div>
                </div>
            </div>
            <div class="col-4 col-md-2">
                <div class="stat-item">
                    <div class="stat-number">10+</div>
                    <div class="stat-label">Žanrova</div>
                </div>
            </div>
            <div class="col-4 col-md-2">
                <div class="stat-item">
                    <div class="stat-number">&#127968;</div>
                    <div class="stat-label">Po gradu</div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- How it works -->
<section class="section" style="background:#FAF6F1">
    <div class="container">
        <h2 class="section-title">Kako funkcioniše?</h2>
        <p class="section-subtitle">Tri koraka do nove knjige</p>
        <div class="row g-4">
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-icon">&#128100;</div>
                    <div class="step-number">1</div>
                    <h3>Registruj se</h3>
                    <p>Kreiraj besplatan nalog, odaberi omiljene žanrove i grad u kom živiš.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-icon">&#128218;</div>
                    <div class="step-number">2</div>
                    <h3>Ponudi ili traži</h3>
                    <p>Dodaj knjige koje imaš ili pretražuj šta su drugi ponudili u tvom gradu.</p>
                </div>
            </div>
            <div class="col-md-4">
                <div class="step-card">
                    <div class="step-icon">&#129309;</div>
                    <div class="step-number">3</div>
                    <h3>Dogovori razmenu</h3>
                    <p>Pošalji zahtev, dogovori se i uživaj u novom naslovu bez ikakvih troškova.</p>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Genres -->
<section class="genres-section">
    <div class="container">
        <h2 class="section-title" style="margin-bottom:0.5rem">Dostupni žanrovi</h2>
        <p class="section-subtitle">Pronađi nešto za svaki ukus</p>
        <div class="text-center">
            @foreach (var zanr in new[] { "Triler", "Romansa", "Sci-Fi", "Fantazija", "Drama", "Horor", "Biografija", "Istorija", "Poezija", "Detektivski" })
            {
                <span class="genre-tag">@zanr</span>
            }
        </div>
    </div>
</section>

<!-- Bottom CTA -->
<section class="cta-section">
    <div class="container">
        <h2>Spreman/a da počneš?</h2>
        <p>Registracija traje manje od minut. Besplatno, zauvek.</p>
        <a asp-controller="Account" asp-action="Register" class="btn-hero-primary">
            Kreiraj nalog &#8594;
        </a>
    </div>
</section>
