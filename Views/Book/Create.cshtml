@model BookExchange.Models.Book

@{
    ViewData["Title"] = "Ponudi svoju knjigu";
    var zanrovi = ViewBag.Zanrovi as List<string>;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <h2 class="fw-bold mb-4">📖 Ponudi svoju knjigu</h2>

            <form asp-action="Create" method="post" enctype="multipart/form-data">

                <div class="mb-3">
                    <label asp-for="Naslov" class="form-label fw-semibold">Naslov</label>
                    <input asp-for="Naslov" class="form-control" placeholder="Unesite naslov knjige" required />
                    <span asp-validation-for="Naslov" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Autor" class="form-label fw-semibold">Autor</label>
                    <input asp-for="Autor" class="form-control" placeholder="Unesite autora" required />
                    <span asp-validation-for="Autor" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Zanr" class="form-label fw-semibold">Žanr</label>
                    <select asp-for="Zanr" class="form-select" required>
                        <option value="">-- Izaberite žanr --</option>
                        @foreach (var zanr in zanrovi!)
                        {
                            <option value="@zanr">@zanr</option>
                        }
                    </select>
                    <span asp-validation-for="Zanr" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Stanje knjige</label>
                    <div class="d-flex gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="IsNovo"
                                   id="novo" value="true" checked />
                            <label class="form-check-label" for="novo">Novo</label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="radio" name="IsNovo"
                                   id="polovno" value="false" />
                            <label class="form-check-label" for="polovno">Polovno</label>
                        </div>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Opis" class="form-label fw-semibold">Opis</label>
                    <textarea asp-for="Opis" class="form-control" rows="4"
                              placeholder="Kratki opis knjige..." required></textarea>
                    <span asp-validation-for="Opis" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-semibold">Naslovna slika</label>
                    <input type="file" name="slika" class="form-control" accept="image/*" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">Objavi knjigu</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Otkaži</a>
                </div>

            </form>
        </div>
    </div>
</div>
